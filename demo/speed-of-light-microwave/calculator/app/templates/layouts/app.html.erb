<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Speed of Light Calculator</title>
    <style>
      :root {
        --brand-purple: #4b1e62;
        --brand-purple-dark: #2c0a3e;
        --chocolate: #6b3a1f;
        --chocolate-dark: #43220d;
        --chocolate-light: #a56a3d;
        --gold: #e8c170;
        --cream: #fbf3e3;
      }

      * { box-sizing: border-box; }

      body {
        font-family: Georgia, 'Times New Roman', serif;
        color: var(--chocolate-dark);
        margin: 0;
        padding: 2.5rem 1rem;
        min-height: 100vh;
        background-color: var(--brand-purple-dark);
        background-image:
          repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.035) 0px, rgba(255, 255, 255, 0.035) 2px, transparent 2px, transparent 34px),
          radial-gradient(circle at 50% 0%, var(--brand-purple), var(--brand-purple-dark) 72%);
      }

      .bar {
        max-width: 560px;
        margin: 0 auto;
        background: var(--cream);
        border: 6px solid var(--chocolate);
        border-radius: 20px;
        padding: 2.2rem 2.4rem 2.5rem;
        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.4), inset 0 0 0 2px rgba(232, 193, 112, 0.5);
      }

      .brand {
        font-family: 'Brush Script MT', 'Segoe Script', cursive;
        font-style: italic;
        text-align: center;
        color: var(--brand-purple);
        font-size: 2.4rem;
        margin: 0 0 0.1rem;
        text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.08);
      }

      .tagline {
        text-align: center;
        color: var(--chocolate);
        font-size: 0.95rem;
        margin: 0 0 1.8rem;
        line-height: 1.5;
      }

      .tagline code {
        background: rgba(107, 58, 31, 0.1);
        padding: 0.05rem 0.35rem;
        border-radius: 4px;
      }

      .gallery-link {
        text-align: center;
        margin: 0 0 1.6rem;
      }

      .gallery-link a {
        color: var(--chocolate);
        font-weight: bold;
        font-size: 0.88rem;
        text-decoration: none;
        border-bottom: 1px dashed var(--chocolate-light);
      }

      .gallery-link a:hover {
        color: var(--brand-purple);
        border-bottom-color: var(--brand-purple);
      }

      .field {
        margin-bottom: 1.1rem;
      }

      label {
        display: block;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        font-size: 0.78rem;
        color: var(--brand-purple);
        margin-bottom: 0.3rem;
      }

      input {
        width: 100%;
        padding: 0.55rem 0.7rem;
        font-size: 1rem;
        font-family: inherit;
        color: var(--chocolate-dark);
        background: #fff;
        border: 2px solid var(--chocolate-light);
        border-radius: 8px;
      }

      input:focus {
        outline: none;
        border-color: var(--brand-purple);
        box-shadow: 0 0 0 3px rgba(75, 30, 98, 0.18);
      }

      button {
        display: block;
        width: 100%;
        margin-top: 0.6rem;
        padding: 0.8rem 1rem;
        font-family: inherit;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 0.95rem;
        color: var(--gold);
        background: linear-gradient(180deg, var(--chocolate-light), var(--chocolate) 55%, var(--chocolate-dark));
        border: none;
        border-radius: 10px;
        cursor: pointer;
        box-shadow: 0 4px 0 var(--chocolate-dark), 0 8px 16px rgba(0, 0, 0, 0.3);
      }

      button:hover { filter: brightness(1.08); }

      button:active {
        transform: translateY(3px);
        box-shadow: 0 1px 0 var(--chocolate-dark);
      }

      .alert {
        margin-top: 1.2rem;
        padding: 0.7rem 1rem;
        background: #fbe4df;
        border-left: 4px solid #a3312a;
        color: #7a241d;
        border-radius: 6px;
        font-size: 0.92rem;
      }

      .result {
        margin-top: 1.6rem;
        background: var(--brand-purple);
        border-radius: 12px;
        padding: 0.4rem 1.2rem;
      }

      .result-table {
        width: 100%;
        border-collapse: collapse;
      }

      .result-table tr:not(:last-child) th,
      .result-table tr:not(:last-child) td {
        border-bottom: 1px solid rgba(255, 255, 255, 0.18);
      }

      .result-table th, .result-table td {
        padding: 0.55rem 0;
        font-size: 0.92rem;
      }

      .result-table th {
        text-align: left;
        font-weight: normal;
        color: var(--gold);
      }

      .result-table td {
        text-align: right;
        font-weight: bold;
        color: var(--cream);
      }

      .page {
        max-width: 720px;
        margin: 0 auto;
      }

      .gallery {
        margin-top: 2.8rem;
      }

      .gallery h2 {
        font-family: 'Brush Script MT', 'Segoe Script', cursive;
        font-style: italic;
        text-align: center;
        color: var(--gold);
        font-size: 2rem;
        margin: 0 0 1.3rem;
        text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.3);
      }

      .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
        gap: 1.1rem;
      }

      .gallery-grid figure {
        margin: 0;
        background: var(--cream);
        border: 4px solid var(--chocolate);
        border-radius: 12px;
        padding: 0.5rem 0.5rem 0.7rem;
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.35);
      }

      .gallery-grid a {
        display: block;
      }

      .gallery-grid img {
        width: 100%;
        height: 150px;
        object-fit: cover;
        border-radius: 6px;
        display: block;
      }

      .gallery-grid figcaption {
        margin-top: 0.5rem;
        font-size: 0.8rem;
        text-align: center;
        color: var(--chocolate-dark);
      }
    </style>
  </head>
  <body>
    <div class="page">
      <%= yield %>
    </div>
  </body>
</html>
